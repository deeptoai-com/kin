# =============================================================================
# Docker-specific Environment Overrides (OxyGenie)
# =============================================================================
# These values override .env when running with Docker Compose.
# Usage: docker compose --env-file .env.docker --env-file .env --profile selfhost up -d --build
# .env loads last and overrides these. Set POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB in .env to keep existing DB.
#
# POSTGRES_* are set here. migrate/app/worker build DATABASE_URL from these (host db). Override POSTGRES_* in .env if needed.
# db creates POSTGRES_DB on first init; create-db creates it if missing (old volumes).
# See README "Quick Start → Option A: Docker Compose" and .env.example.

# =============================================================================
# CLIENT ENVIRONMENT VARIABLES (baked in at build time)
# =============================================================================
VITE_BASE_URL="http://localhost:5050"

# =============================================================================
# NETWORK CONFIGURATION (Docker container names instead of localhost)
# =============================================================================

# Database (container: db). Override in .env when using Docker. db creates POSTGRES_DB on first init.
# Containers use DATABASE_URL built from POSTGRES_* (host db); DATABASE_URL below is reference only.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="oxygenie"
DATABASE_URL="postgresql://postgres:postgres@db:5432/oxygenie"

# Redis (container: redis)
REDIS_URL="redis://redis:6379"

# Meilisearch (container: meilisearch). Override MEILI_MASTER_KEY in .env for production.
MEILI_MASTER_KEY="changeme-master-key"
MEILI_HOST="http://meilisearch:7700"
MEILI_API_KEY="${MEILI_MASTER_KEY}"

# MinIO/S3 (container: minio)
S3_ENDPOINT="http://minio:9000"
S3_BUCKET="oxygenie-files"
MINIO_BUCKET="oxygenie-files"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"

# =============================================================================
# AUTHENTICATION (Docker port mapping: 5050:5000)
# =============================================================================
BETTER_AUTH_URL="http://localhost:5050"

# =============================================================================
# CLAUDE AGENT SDK (WebSocket sidecar)
# =============================================================================
# WebSocket URL for frontend (mapped port 3051 on host)
VITE_WS_URL="ws://localhost:3051/ws/agent"

# Structured Outputs for Artifacts (auto-triggered when prompt includes file extension)
# Set to 'true' to enable artifact metadata generation via Structured Outputs
ENABLE_STRUCTURED_OUTPUTS="true"

# =============================================================================
# MCP STORE & PYTHON RUNNER (Claude Agent SDK)
# =============================================================================
# MCP Store location (relative to /app inside container)
CLAUDE_MCP_STORE_DIR="src/mcp-store"
MCP_STORE_DIR="src/mcp-store"

# Python runner limits for MCP execution
PYTHON_RUNNER_TIMEOUT_MS="10000"
PYTHON_RUNNER_MAX_OUTPUT_BYTES="512000"
PYTHON_RUNNER_MAX_CODE_BYTES="200000"

# Optional: Cloudflare Tunnel (profile tunnel). Set in .env when using --profile tunnel.
CLOUDFLARED_TUNNEL_TOKEN=""
