# Dokploy 环境变量配置示例
# 
# 使用方法：
# 1. 复制此文件到 Dokploy 的 "Environment Variables" 配置中
# 2. 替换所有占位符值（your-xxx）为实际值
# 3. 删除或注释掉不需要的可选变量
#
# 标注说明：
# ✅ 必需变量 - 必须填写，否则应用无法启动
# ⚠️  重要变量 - 强烈建议填写，影响核心功能
# 🔵 可选变量 - 根据需要填写，有默认值或可选功能
# ❌ 不推荐 - 通常不需要修改，保留默认值即可

# ============================================================================
# 应用基础配置
# ============================================================================

# ✅ 应用名称（Docker 容器和服务命名）
# ⚠️  重要：如果应用名称包含空格或特殊字符，必须同时设置 APP_NAME_SANITIZED
# Docker volume 和 network 名称不允许包含空格，只能使用 [a-zA-Z0-9][a-zA-Z0-9_.-]
# 示例：如果 APP_NAME="DeeptoAI Agents"，则 APP_NAME_SANITIZED="DeeptoAI-Agents"
APP_NAME=claude-agent-chat

# 🔵 应用名称（规范化版本，用于 Docker volume 和 network 命名）
# 如果 APP_NAME 包含空格或特殊字符，必须设置此变量
# 规则：将空格替换为连字符（-），移除其他特殊字符
# 如果未设置，将使用 APP_NAME 的默认值（claude-agent-chat）
# 示例：
#   APP_NAME="DeeptoAI Agents" → APP_NAME_SANITIZED="DeeptoAI-Agents"
#   APP_NAME="My App!" → APP_NAME_SANITIZED="My-App"
APP_NAME_SANITIZED=claude-agent-chat

# ✅ 应用域名（Traefik 路由配置必需）
APP_HOSTNAME=your-domain.com

# ⚠️  应用镜像（如果使用 Docker 镜像仓库）
# 格式：registry.com/namespace/image:tag
APP_IMAGE=your-registry/claude-agent-chat:latest
APP_TAG=latest

# ============================================================================
# 数据库配置（PostgreSQL）
# ============================================================================

# ✅ PostgreSQL 用户名
POSTGRES_USER=claude_user

# ✅ PostgreSQL 密码（请使用强密码）
POSTGRES_PASSWORD=your_secure_database_password_here

# ✅ PostgreSQL 数据库名
POSTGRES_DB=claude_agent_chat

# ✅ 数据库连接字符串（完整格式）
# 格式：postgresql://username:password@host:port/database
# ⚠️  重要：如果密码包含特殊字符，需要进行 URL 编码：
#   - # → %23
#   - @ → %40
#   - : → %3A
#   - / → %2F
#   - ? → %3F
#   - & → %26
#   - = → %3D
#   - % → %25
#   - 空格 → %20
# 示例：如果密码是 "2wsx#EDC2026db"，DATABASE_URL 应该是：
#   postgresql://user:2wsx%23EDC2026db@db:5432/database
# 在线工具：https://www.urlencoder.org/ 或使用 Python: urllib.parse.quote(password)
DATABASE_URL=postgresql://claude_user:your_secure_database_password_here@db:5432/claude_agent_chat

# ============================================================================
# MinIO / S3 对象存储配置
# ============================================================================

# ✅ MinIO 管理员用户名
MINIO_ROOT_USER=minioadmin

# ✅ MinIO 管理员密码（请使用强密码）
# ⚠️  重要：如果密码包含特殊字符（如 #, $, ! 等），请确保在 Dokploy 中正确设置
# 建议：避免使用 # 字符，或使用引号包裹密码值
# 示例：MINIO_ROOT_PASSWORD="2wsx#EDC2026minio" 或使用不包含 # 的密码
MINIO_ROOT_PASSWORD=your_secure_minio_password_here

# ✅ S3 存储桶名称
MINIO_BUCKET=constructa-files

# 🔵 S3 区域（默认：us-east-1）
S3_REGION=us-east-1

# 🔵 S3 路径样式（默认：1，MinIO 需要）
S3_ENABLE_PATH_STYLE=1

# 🔵 S3 预览 URL 过期时间（秒，默认：900）
S3_PREVIEW_URL_EXPIRE_IN=900

# ============================================================================
# Redis 配置（缓存和任务队列）
# ============================================================================

# ✅ Redis 连接 URL
# 格式：redis://host:port
REDIS_URL=redis://redis:6379

# ============================================================================
# Meilisearch 配置（全文搜索）
# ============================================================================

# ✅ Meilisearch 主密钥（请使用强密钥）
# 生成方式：
#   - 方法 1（推荐）：openssl rand -hex 32
#   - 方法 2：openssl rand -base64 32
#   - 方法 3：使用在线工具生成随机字符串（至少 32 个字符）
# 注意：Master Key 可以是任意字符串，但建议使用强随机字符串（至少 32 个字符）
MEILI_MASTER_KEY=your_secure_meilisearch_master_key_here

# 🔵 Meilisearch API 密钥（默认使用 MEILI_MASTER_KEY）
MEILI_API_KEY=

# 🔵 搜索索引启动时重建（默认：false）
SEARCH_REINDEX_ON_BOOT=false

# ============================================================================
# 认证配置（Better Auth）
# ============================================================================

# ✅ 认证密钥（用于加密 session，请使用强随机字符串）
# 生成方式：openssl rand -base64 32
BETTER_AUTH_SECRET=your_random_secret_key_here_minimum_32_characters

# ✅ 外部认证 URL（用于浏览器重定向）
BETTER_AUTH_URL=https://your-domain.com

# ✅ 内部认证 URL（应用内部调用）
BETTER_AUTH_INTERNAL_URL=http://localhost:5000

# ============================================================================
# 第三方登录配置（OAuth - 可选）
# ============================================================================

# 🔵 GitHub OAuth 配置（后端）
# 如果配置了这些变量，用户可以通过 GitHub 账号登录
# 获取方式：https://github.com/settings/developers
# 
# 配置 OAuth App 时的填写说明：
# - Application name: 你的应用名称（如：DeeptoAI）
# - Homepage URL: https://your-domain.com
# - Authorization callback URL: https://your-domain.com/api/auth/callback/github
#   ⚠️ 必须完全匹配，包括协议（https）和路径（/api/auth/callback/github）
# - Enable Device Flow: ❌ 不需要勾选（仅用于命令行工具、IoT 设备等无头应用）
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# 🔵 Google OAuth 配置（后端）
# 如果配置了这些变量，用户可以通过 Google 账号登录
# 获取方式：https://console.cloud.google.com/apis/credentials
# 配置 OAuth 2.0 Client 时的 Authorized redirect URI：https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# 🔵 GitHub OAuth 配置（前端 - 必须与后端同时配置）
# 注意：前端只需要 CLIENT_ID，不需要 SECRET
# 必须与 GITHUB_CLIENT_ID 的值相同（用于构建时注入前端）
VITE_GITHUB_CLIENT_ID=your_github_oauth_app_client_id

# 🔵 Google OAuth 配置（前端 - 必须与后端同时配置）
# 注意：前端只需要 CLIENT_ID，不需要 SECRET
# 必须与 GOOGLE_CLIENT_ID 的值相同（用于构建时注入前端）
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ============================================================================
# AI 服务配置
# ============================================================================

# ✅ Claude Agent SDK API 密钥（Anthropic API Key）
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key-here

# 🔵 Claude Agent SDK 基础 URL（可选，用于自定义端点）
ANTHROPIC_BASE_URL=

# 🔵 Claude Agent SDK 模型名称（可选，使用默认模型）
ANTHROPIC_MODEL=

# ✅ Zhipu AI API 密钥（Mastra AI SDK）
ZHIPU_API_KEY=your_zhipu_api_key_here

# ============================================================================
# Claude Agent 配置
# ============================================================================

# 🔵 Claude Agent 会话存储根目录（默认：/data/users）
CLAUDE_SESSIONS_ROOT=/data/users

# 🔵 启用沙盒环境（默认：false，生产环境建议关闭）
SANDBOX_ENABLED=false

# 🔵 启用结构化输出（默认：false，用于 Artifacts 增强功能）
ENABLE_STRUCTURED_OUTPUTS=false

# ============================================================================
# WebSocket 配置
# ============================================================================

# ✅ WebSocket URL（前端配置，用于连接到 WebSocket 服务器）
# 格式：wss://domain.com/ws/agent（HTTPS）或 ws://domain.com/ws/agent（HTTP）
VITE_WS_URL=wss://your-domain.com/ws/agent

# 🔵 WebSocket 服务器端口（默认：3001，通常不需要修改）
WS_PORT=3001

# 🔵 应用 URL（WebSocket 服务器认证使用，默认：http://localhost:5000）
APP_URL=http://localhost:5000

# ============================================================================
# 邮件配置
# ============================================================================

# 🔵 邮件提供商（smtp | resend | console | mailhog）
# smtp: 使用 SMTP 服务器
# resend: 使用 Resend 服务
# console: 仅用于开发，输出到控制台
# mailhog: 仅用于开发，使用 MailHog
EMAIL_PROVIDER=smtp

# 🔵 发件人邮箱地址
EMAIL_FROM=noreply@your-domain.com

# SMTP 配置（EMAIL_PROVIDER=smtp 时使用）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_SECURE=true

# Resend 配置（EMAIL_PROVIDER=resend 时使用）
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================================================
# 后台任务配置（Worker）
# ============================================================================

# 🔵 BullMQ 任务队列前缀（默认：constructa）
BULLMQ_PREFIX=constructa

# 🔵 每日信用额度补充 Cron 表达式（默认：每天 3:00 AM）
DAILY_CREDIT_REFILL_CRON=0 3 * * *

# 🔵 每日信用额度补充任务 URL
JOB_DAILY_CREDIT_REFILL_URL=http://app:5000/api/jobs/daily-credit-refill

# 🔵 任务密钥（用于任务认证，可选）
JOBS_SECRET=

# ============================================================================
# Polar 计费配置（可选，如果使用 Polar.sh）
# ============================================================================

# 🔵 Polar 服务器环境（production | sandbox）
POLAR_SERVER=production

# 🔵 Polar Access Token
POLAR_ACCESS_TOKEN=

# 🔵 Polar Webhook Secret
POLAR_WEBHOOK_SECRET=

# 🔵 Polar Organization ID
POLAR_ORGANIZATION_ID=

# 🔵 Polar 产品 ID（月度订阅）
POLAR_PRODUCT_PRO_MONTHLY=
POLAR_PRODUCT_BUSINESS_MONTHLY=

# 🔵 Polar 产品 ID（一次性购买）
POLAR_PRODUCT_CREDITS_50=
POLAR_PRODUCT_CREDITS_100=

# 🔵 结账成功/取消重定向 URL
CHECKOUT_SUCCESS_URL=https://your-domain.com/billing/success
CHECKOUT_CANCEL_URL=https://your-domain.com/dashboard

# ============================================================================
# Sentry 错误监控配置（可选）
# ============================================================================

# 🔵 Sentry DSN（后端）
SENTRY_DSN=

# 🔵 Sentry DSN（前端）
VITE_SENTRY_DSN=

# 🔵 Sentry 日志记录（默认：false）
SENTRY_LOGGING=false
VITE_SENTRY_LOGGING=false

# 🔵 Sentry 日志级别（默认：info）
SENTRY_LOG_LEVEL=info
VITE_SENTRY_LOG_LEVEL=info

# 🔵 Sentry 性能追踪采样率（0.0-1.0，默认：1.0）
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0

# 🔵 Sentry 会话回放采样率（0.0-1.0，默认：0.1）
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1

# ============================================================================
# 节点环境配置
# ============================================================================

# ✅ 节点环境（固定为 production）
NODE_ENV=production

# ❌ 自动迁移控制（生产环境固定为 false，使用 Docker Compose migrate 服务）
# 开发环境可以设置为 true 以便自动迁移
# 生产环境必须为 false，因为迁移由 docker-compose.dokploy.yml 中的 migrate 服务处理
AUTO_MIGRATE=false

# 🔵 应用端口（HTTP，默认：5000，通常不需要修改）
PORT=5000

# ============================================================================
# 必需变量检查清单
# ============================================================================
#
# 部署前请确认以下变量都已填写：
#
# ✅ APP_NAME
# ✅ APP_HOSTNAME
# ✅ POSTGRES_USER
# ✅ POSTGRES_PASSWORD
# ✅ POSTGRES_DB
# ✅ DATABASE_URL
# ✅ MINIO_ROOT_USER
# ✅ MINIO_ROOT_PASSWORD
# ✅ MINIO_BUCKET
# ✅ MEILI_MASTER_KEY
# ✅ BETTER_AUTH_SECRET
# ✅ BETTER_AUTH_URL
# ✅ BETTER_AUTH_INTERNAL_URL
# ✅ ANTHROPIC_API_KEY
# ✅ ZHIPU_API_KEY
# ✅ VITE_WS_URL
#
# ============================================================================
# 安全建议
# ============================================================================
#
# 1. 所有密码和密钥应使用强随机字符串
# 2. 不要将包含敏感信息的 .env 文件提交到版本控制
# 3. 定期轮换密钥和密码
# 4. 使用密钥管理服务（如 Docker Secrets、Vault）管理敏感信息
# 5. BETTER_AUTH_SECRET 至少 32 个字符
# 6. 数据库密码、MinIO 密码应使用强密码（至少 16 个字符）
# 7. MEILI_MASTER_KEY 建议至少 32 个字符（推荐 64 个字符）
#
# 生成强密码/密钥的命令：
# - BETTER_AUTH_SECRET: openssl rand -base64 32
# - MEILI_MASTER_KEY: openssl rand -hex 32（推荐，生成 64 字符）或 openssl rand -base64 32
# - 数据库密码: openssl rand -base64 24
# - MinIO 密码: openssl rand -base64 24
#
# ============================================================================
